{
  "name": "700sinmungo",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:sandbox": "wrangler pages dev dist --ip 0.0.0.0 --port 3000",
    "dev:d1": "wrangler pages dev dist --d1=DB --local --ip 0.0.0.0 --port 3000",
    "build:client": "vite build --mode client",
    "build:worker": "vite build",
    "build": "npm run build:client && npm run build:worker",
    "preview": "wrangler pages dev dist",
    "deploy": "npm run build && wrangler pages deploy dist",
    "deploy:prod": "npm run build && wrangler pages deploy dist --project-name 700sinmungo",
    "clean": "rm -rf dist .wrangler",
    "lint": "tsc --noEmit",
    "db:migrate:local": "wrangler d1 migrations apply 700sinmungo-production --local",
    "db:migrate:prod": "wrangler d1 migrations apply 700sinmungo-production",
    "db:seed": "wrangler d1 execute 700sinmungo-production --local --file=./seed.sql",
    "db:reset": "rm -rf .wrangler/state/v3/d1 && npm run db:migrate:local && npm run db:seed",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "hono": "^4.12.8",
    "i18next": "^25.8.13",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-dropzone": "^15.0.0",
    "react-i18next": "^16.5.4",
    "react-router-dom": "^7.13.1",
    "react-select": "^5.10.2",
    "recharts": "^3.7.0",
    "tailwind-merge": "^3.5.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260317.1",
    "@hono/vite-cloudflare-pages": "^0.4.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/vite": "^4.1.14",
    "@types/node": "^22.14.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.27",
    "esbuild": "^0.27.4",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "wrangler": "^4.75.0"
  }
}
